{
  "version": "2026.05.10",
  "comment": "Canonical env-var contract. New entries added here graduate to every spoke's .env.example on the next sync.",
  "required": [
    { "key": "NEXT_PUBLIC_SITE_NAME",        "purpose": "Brand name as shown to users" },
    { "key": "NEXT_PUBLIC_SITE_SHORT_NAME",  "purpose": "≤12 chars for manifest short_name" },
    { "key": "NEXT_PUBLIC_SITE_DOMAIN",      "purpose": "Bare hostname (no protocol)" },
    { "key": "NEXT_PUBLIC_SITE_URL",         "purpose": "Canonical absolute URL, no trailing slash" },
    { "key": "NEXT_PUBLIC_SITE_DESCRIPTION", "purpose": "OG description, llms.txt header" },
    { "key": "NEXT_PUBLIC_SITE_CONTACT_EMAIL", "purpose": "Surfaced on /contact and security.txt" }
  ],
  "seo_verification": [
    { "key": "NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION", "purpose": "GSC site claim token" },
    { "key": "NEXT_PUBLIC_BING_SITE_VERIFICATION",   "purpose": "Bing Webmaster claim token" }
  ],
  "analytics": [
    { "key": "NEXT_PUBLIC_VERCEL_ANALYTICS",   "default": "1", "purpose": "Toggle Vercel Analytics + Speed Insights" },
    { "key": "NEXT_PUBLIC_CLARITY_PROJECT_ID", "purpose": "Microsoft Clarity (consent-gated)" },
    { "key": "NEXT_PUBLIC_PLAUSIBLE_DOMAIN",   "optional": true },
    { "key": "NEXT_PUBLIC_GA_ID",              "optional": true }
  ],
  "ads": [
    { "key": "NEXT_PUBLIC_AD_PROVIDER",        "default": "none", "values": ["none", "adsense", "mediavine", "carbon"] },
    { "key": "NEXT_PUBLIC_ADSENSE_CLIENT_ID",  "optional": true },
    { "key": "NEXT_PUBLIC_MEDIAVINE_SITE_ID",  "optional": true },
    { "key": "NEXT_PUBLIC_CARBONADS_SERVE_ID", "optional": true },
    { "key": "NEXT_PUBLIC_CARBONADS_PLACEMENT","optional": true }
  ],
  "affiliate": [
    { "key": "NEXT_PUBLIC_AFFILIATE_ENABLED",  "default": "0" },
    { "key": "NEXT_PUBLIC_AFFILIATE_URL",      "optional": true },
    { "key": "NEXT_PUBLIC_AFFILIATE_LABEL",    "optional": true },
    { "key": "NEXT_PUBLIC_AFFILIATE_PROVIDER", "optional": true, "purpose": "Analytics tag for click telemetry" }
  ],
  "email": [
    { "key": "RESEND_API_KEY",      "secret": true, "optional": true },
    { "key": "RESEND_AUDIENCE_ID",  "optional": true }
  ],
  "stripe": [
    { "key": "STRIPE_SECRET_KEY",                "secret": true, "optional": true },
    { "key": "STRIPE_WEBHOOK_SECRET",            "secret": true, "optional": true },
    { "key": "NEXT_PUBLIC_PRO_ENABLED",          "default": "0" },
    { "key": "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY", "optional": true },
    { "key": "NEXT_PUBLIC_STRIPE_PRICE_MONTHLY", "optional": true },
    { "key": "NEXT_PUBLIC_STRIPE_PRICE_YEARLY",  "optional": true }
  ],
  "alt_monetization": [
    { "key": "NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID", "optional": true },
    { "key": "NEXT_PUBLIC_GUMROAD_PRODUCT_URL",    "optional": true },
    { "key": "NEXT_PUBLIC_GUMROAD_PRICE",          "optional": true }
  ],
  "embed": [
    { "key": "NEXT_PUBLIC_EMBED_ENABLED", "default": "0" }
  ]
}
