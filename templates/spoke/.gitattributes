# Normalize line endings on commit; check out as native on Windows.
* text=auto eol=lf

# Treat lockfiles as binary to avoid merge conflicts.
pnpm-lock.yaml binary
package-lock.json binary
yarn.lock binary

# Per-language overrides
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mdx  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Binary assets
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff binary
*.woff2 binary
*.pdf  binary
